.navBar
  %ul
    %li.navBar__item= link_to "Máy chủ mail", organization_root_path(organization), :class => ['navBar__link', active_nav == :servers ? 'is-active' : '']
    %li.navBar__item= link_to "Tên miền", organization_domains_path(organization), :class => ['navBar__link', active_nav == :domains ? 'is-active' : '']
    %li.navBar__item= link_to "Cài đặt", organization_settings_path(organization), :class => ['navBar__link', active_nav == :settings ? 'is-active' : '']
    - if OmmicomMail.ip_pools?
      %li.navBar__item= link_to "IPs", organization_ip_pools_path(organization), :class => ['navBar__link', active_nav == :ips ? 'is-active' : '']
    - if current_user.admin?
      %li.navBar__item= link_to "Xóa tổ chức", organization_delete_path(organization), :class => ['navBar__link', active_nav == :delete ? 'is-active' : '']
