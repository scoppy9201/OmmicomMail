- page_title << "Trang chủ"

.pageHeader
  %p.pageHeader__eyebrow Hệ sinh thái Ommicom
  %h1.pageHeader__title Xin chào, #{current_user.first_name}
  %p.pageHeader__text Quản lý tổ chức, máy chủ mail, tên miền, thông tin xác thực và luồng gửi nhận trong một không gian làm việc.

.pageContent.pageContent--compact.organizationWelcome

  - if @organizations.empty?
    .noData.noData--clean
      %p.noData__title Chưa có tổ chức nào.
      - if current_user.admin?
        %p.noData__text
          Bạn cần tạo một tổ chức trước khi có thể quản lý hệ thống mail.
          Hãy dùng nút bên dưới để tạo tổ chức đầu tiên.
        %p.noData__button= link_to "Tạo tổ chức đầu tiên", :new_organization, :class => 'button button--positive'
      - else
        %p.noData__text
          Bạn chưa có quyền truy cập tổ chức nào. Vui lòng liên hệ quản trị viên để được cấp quyền.
  - else
    .organizationWelcome__panel
      .organizationWelcome__intro
        %p.organizationWelcome__eyebrow Không gian làm việc
        %h2.organizationWelcome__title Tổ chức của bạn
        %p.organizationWelcome__text
          Chọn một tổ chức để quản lý máy chủ mail, tên miền, định tuyến, thông tin xác thực và cấu hình gửi nhận.

      %ul.largeList.organizationWelcome__list
        - for organization in @organizations
          %li.largeList__item
            = link_to organization_root_path(organization), :class => 'largeList__link' do
              %span.largeList__avatar= organization.name.first.upcase
              %span.largeList__content
                %span.largeList__title= organization.name
                %span.largeList__subText Không gian vận hành hệ thống mail
              %span.largeList__arrow →

      - if current_user.admin?
        .organizationWelcome__actions
          = link_to "Tạo tổ chức", :new_organization, :class => 'button button--positive'
