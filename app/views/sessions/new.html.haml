- page_title << "Login"
.subPageBox__title.loginForm__brand
  .loginForm__mark OM
  %p.loginForm__eyebrow Secure mail operations
  %h1.loginForm__heading Welcome to OmmicomMail
  %p.loginForm__intro Sign in to manage your mail servers, domains, credentials, and delivery flow.
= display_flash

.subPageBox__content
  = form_tag login_path, :class => 'loginForm' do
    = hidden_field_tag 'return_to', params[:return_to]

    - if OmmicomMail::Config.oidc.enabled?
      .loginForm__oidcButton
        = link_to "Login with #{OmmicomMail::Config.oidc.name}", "/auth/oidc", method: :post, class: 'button button--full'

    - if OmmicomMail::Config.oidc.enabled? && OmmicomMail::Config.oidc.local_authentication_enabled?
      .loginForm__divider
      %p.loginForm__localTitle or login with a local user

    - if OmmicomMail::Config.oidc.local_authentication_enabled?
      %p.loginForm__input= text_field_tag 'email_address', '', :type => 'email', :spellcheck => 'false', :class => 'input input--text input--onWhite', :placeholder => "Your e-mail address", :autofocus => !OmmicomMail::Config.oidc.enabled?, :tabindex => 1
      %p.loginForm__input= password_field_tag 'password', '', :class => 'input input--text input--onWhite', :placeholder => "Your password", :tabindex => 2
      .loginForm__submit
        %ul.loginForm__links
          %li= link_to "Forgot password?", login_reset_path(:return_to => params[:return_to])
        %p= submit_tag "Sign in", :class => 'button button--positive', :tabindex => 3
