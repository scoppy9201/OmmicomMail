- page_title << "Đặt lại mật khẩu"
.subPageBox__title
  Chọn mật khẩu mới
= display_flash

.subPageBox__content
  %p.subPageBox__text
    Nhập mật khẩu mới cho tài khoản của bạn và xác nhận lại để hoàn tất quá trình đặt lại mật khẩu.
  = form_tag '', :class => 'loginForm' do
    = error_messages_for @user
    = hidden_field_tag 'return_to', params[:return_to]
    %p.loginForm__input= password_field_tag 'password', params[:password], :class => 'input input--text input--onWhite', :placeholder => "Nhập mật khẩu mới", :autofocus => true, :tabindex => 1
    %p.loginForm__input= password_field_tag 'password_confirmation', params[:password_confirmation], :class => 'input input--text input--onWhite', :placeholder => "Nhập lại mật khẩu để xác nhận", :tabindex => 2

    .loginForm__submit
      %ul.loginForm__links
        %li= link_to "Quay lại đăng nhập", login_path(:return_to => params[:return_to])
      %p= submit_tag "Đăng nhập", :class => 'button button--positive', :tabindex => 3

