.navBar.navBar--secondary
  %ul
    %li.navBar__item= link_to "Email gửi đi", [:outgoing, organization, @server, :messages], :class => ['navBar__link', active_nav == :outgoing ? 'is-active' : '']
    %li.navBar__item= link_to "Email nhận vào", [:incoming, organization, @server, :messages], :class => ['navBar__link', active_nav == :incoming ? 'is-active' : '']
    %li.navBar__item= link_to "Hàng đợi", [:queue, organization, @server], :class => ['navBar__link', active_nav == :queue ? 'is-active' : '']
    %li.navBar__item= link_to "Đang giữ", [:held, organization, @server, :messages], :class => ['navBar__link', active_nav == :held ? 'is-active' : '']
    %li.navBar__item= link_to "Gửi email", [:new, organization, @server, :message], :class => ['navBar__link', active_nav == :new ? 'is-active' : '']
    %li.navBar__item= link_to "Chặn gửi", [:suppressions, organization, @server, :messages], :class => ['navBar__link', active_nav == :suppressions ? 'is-active' : '']
