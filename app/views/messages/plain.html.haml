- page_title << @server.name
- page_title << "Email"
- page_title << "Email ##{@message.id}"
- page_title << "Văn bản"
= render 'servers/sidebar', :active_server => @server
= render 'servers/header', :active_nav => :messages
= render 'header', :active_nav => @message.scope.to_sym
= render 'message_header', :active_nav => :plain
.pageContent.pageContent--compact
  - if @message.plain_body.blank?
    .noData.noData--clean
      %h2.noData__title Email này không có nội dung văn bản.
      %p.noData__text
        Có thể hệ thống không còn lưu dữ liệu gốc của email này
        hoặc email không có phần văn bản thuần.
  - else
    %pre.codeBlock= @message.plain_body
