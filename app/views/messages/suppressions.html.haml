- page_title << @server.name
- page_title << "Email"
- page_title << "Danh sách chặn gửi"
= render 'servers/sidebar', :active_server => @server
= render 'servers/header', :active_nav => :messages
= render 'header', :active_nav => :suppressions
.pageContent.pageContent--compact
  - if @suppressions[:records].empty?
    .noData.noData--clean
      %h2.noData__title Chưa có địa chỉ nào trong danh sách chặn gửi.
      %p.noData__text
        Khi email không thể chuyển phát, địa chỉ nhận sẽ được thêm vào danh sách chặn gửi
        để ngăn các email tiếp theo gửi tới cùng người nhận.
  - else
    %p.pageContent__intro.u-margin
      Khi email không thể chuyển phát, địa chỉ nhận sẽ được thêm vào danh sách chặn gửi
      để ngăn các email tiếp theo gửi tới cùng người nhận. Người nhận sẽ tự động được xóa khỏi danh sách sau #{OmmicomMail::Config.postal.default_suppression_list_automatic_removal_days} ngày.
    %ul.suppressionList
      - for suppression in @suppressions[:records]
        %li.suppressionList__item
          .suppressionList__left
            %p.suppressionList__address= link_to suppression['address'], outgoing_organization_server_messages_path(organization, @server, :query => "to: #{suppression['address']}")
            %p.suppressionList__reason= suppression['reason'].capitalize
          .suppressionList__right
            %p.suppressionList__timestamp Đã thêm #{Time.zone.at(suppression['timestamp']).to_fs(:long)}
            %p.suppressionList__timestamp
              Hết hạn #{Time.zone.at(suppression['keep_until']).to_fs(:long)}
              - if suppression['keep_until'] < Time.now.to_f
                %span.u-red đã hết hạn
    = render 'shared/message_db_pagination', :data => @suppressions, :name => "suppression"
